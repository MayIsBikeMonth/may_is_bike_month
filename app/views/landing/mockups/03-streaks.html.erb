<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>May is Bike Month 2025 — Streaks</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<%= render "landing/mockups/head_includes" %>
<style>
  :root {
    --bg: #0b0c12;
    --panel: #14161e;
    --line: #232634;
    --muted: #6e7388;
    --fg: #f0eef5;
    --dim: #b5b3c4;
    --accent: #c084fc;
    --accent-soft: #5b21b6;
    --hot: #f472b6;
    --weekend: rgba(255,255,255,0.03);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg);
    font-family: "Inter", system-ui, sans-serif; font-size: 13px; line-height: 1.5; }
  body {
    background:
      radial-gradient(1200px 600px at 80% -10%, rgba(192,132,252,0.10), transparent 60%),
      radial-gradient(900px 500px at -10% 110%, rgba(244,114,182,0.08), transparent 60%),
      var(--bg);
  }
  .wrap { max-width: 1340px; margin: 0 auto; padding: 36px 28px 80px; }

  header { display: grid; grid-template-columns: 1fr auto; gap: 28px; align-items: end;
    margin-bottom: 28px; }
  header h1 { font-family: "Inter", sans-serif; font-weight: 700; font-size: 36px;
    letter-spacing: -1px; margin: 0; }
  header h1 b { color: var(--accent); font-weight: 700; }
  header .sub { color: var(--dim); margin-top: 6px; font-size: 13px; max-width: 540px; }
  header .meta { display: flex; gap: 28px; font-family: "JetBrains Mono", monospace; }
  header .meta .num { font-size: 24px; font-weight: 600; color: var(--fg); }
  header .meta .label { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: .14em; margin-top: 2px; }

  .axis { display: grid; grid-template-columns: 200px 1fr 160px; gap: 18px; align-items: center;
    padding: 10px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);
    color: var(--muted); font-family: "JetBrains Mono", monospace; font-size: 11px; margin-bottom: 6px; }
  .axis .days { display: grid; grid-template-columns: repeat(31, 1fr); text-align: center; }
  .axis .days span.we { color: var(--accent); }

  .row { display: grid; grid-template-columns: 200px 1fr 160px; gap: 18px; align-items: center;
    padding: 14px 0; border-bottom: 1px solid var(--line); }
  .row .who { display: flex; align-items: center; gap: 12px; }
  .row .who .rank { font-family: "JetBrains Mono", monospace; color: var(--muted);
    font-size: 12px; min-width: 28px; }
  .row .who .name { font-weight: 600; font-size: 14px; color: var(--fg); }
  .row .who .handle { color: var(--muted); font-family: "JetBrains Mono", monospace; font-size: 11px; display: block; margin-top: 1px; }

  .rope { display: grid; grid-template-columns: repeat(31, 1fr);
    align-items: center; height: 36px; position: relative; }
  .bead { display: flex; align-items: center; justify-content: center; height: 100%;
    position: relative; }
  .bead.we::before {
    content: ""; position: absolute; inset: 4px 0;
    background: var(--weekend); border-radius: 2px;
  }
  .bead .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(255,255,255,0.07);
    position: relative; z-index: 2;
  }
  .bead[data-l="1"] .dot { background: rgba(192,132,252,0.4); width: 8px; height: 8px; }
  .bead[data-l="2"] .dot { background: rgba(192,132,252,0.7); width: 10px; height: 10px; }
  .bead[data-l="3"] .dot { background: var(--accent); width: 12px; height: 12px; box-shadow: 0 0 8px rgba(192,132,252,0.6); }
  .bead[data-l="4"] .dot { background: var(--accent); width: 14px; height: 14px; box-shadow: 0 0 12px rgba(192,132,252,0.85); }
  .bead[data-l="5"] .dot { background: var(--hot); width: 16px; height: 16px; box-shadow: 0 0 16px rgba(244,114,182,0.9); }
  /* Connection lines between consecutive ridden days */
  .bead.conn::after {
    content: ""; position: absolute; left: -50%; right: 50%;
    top: 50%; height: 2px;
    background: linear-gradient(90deg, var(--accent-soft), var(--accent));
    transform: translateY(-50%);
    z-index: 1;
    opacity: 0.6;
  }

  .row .totals { text-align: right; font-family: "JetBrains Mono", monospace; }
  .row .totals .streak { display: flex; align-items: baseline; justify-content: flex-end; gap: 6px; }
  .row .totals .streak b { font-size: 26px; color: var(--accent); font-weight: 700; }
  .row .totals .streak span { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: .12em; }
  .row .totals .line { font-size: 11px; color: var(--dim); margin-top: 2px; }

  .footer { display: flex; justify-content: space-between; margin-top: 30px; color: var(--muted);
    font-family: "JetBrains Mono", monospace; font-size: 11px; text-transform: uppercase; letter-spacing: .12em; }
  .footer a { color: var(--accent); text-decoration: none; }
  .footer a:hover { text-decoration: underline; }
  .legend { display: flex; align-items: center; gap: 16px; }
  .legend span { display: inline-flex; align-items: center; gap: 6px; }
  .legend .l { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); display: inline-block; }
  .legend .l.s { width: 6px; height: 6px; background: rgba(192,132,252,0.4); }
  .legend .l.h { background: var(--hot); }
  .legend .ln { width: 22px; height: 2px; background: var(--accent); }
</style>
</head>
