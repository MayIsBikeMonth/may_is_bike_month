<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>May is Bike Month 2025 — Sparkbar</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<%= render "landing/mockups/head_includes" %>
<style>
  :root {
    --bg: #f4f1ea;
    --paper: #fbf8f1;
    --ink: #1a1a1a;
    --muted: #7a7368;
    --line: rgba(0,0,0,0.08);
    --bar: #1a1a1a;
    --warm: #d97a3a;
    --hot:  #c0392b;
    --weekend: rgba(0,0,0,0.04);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink);
    font-family: "Space Grotesk", system-ui, sans-serif; font-size: 13px; line-height: 1.4; }
  .wrap { max-width: 1340px; margin: 0 auto; padding: 32px 28px 80px; }

  header { display: grid; grid-template-columns: 1fr auto; gap: 28px; align-items: end;
    border-bottom: 2px solid var(--ink); padding-bottom: 18px; margin-bottom: 22px; }
  header h1 { font-family: "Space Mono", monospace; font-weight: 700; font-size: 38px;
    letter-spacing: -1px; margin: 0; }
  header .sub { color: var(--muted); margin-top: 6px; font-size: 13px; }
  header .meta { display: flex; gap: 22px; font-family: "Space Mono", monospace; }
  header .meta div { text-align: right; }
  header .meta .num { font-size: 22px; font-weight: 700; }
  header .meta .label { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: .1em; }

  .axis { display: grid; grid-template-columns: 220px 1fr 150px; gap: 16px; align-items: center;
    padding: 8px 0; border-bottom: 1px solid var(--line); color: var(--muted);
    font-family: "Space Mono", monospace; font-size: 11px; margin-bottom: 4px; }
  .axis .days { display: grid; grid-template-columns: repeat(31, 1fr); text-align: center; }
  .axis .days span.we { color: var(--ink); font-weight: 700; }

  .row { display: grid; grid-template-columns: 220px 1fr 150px; gap: 16px; align-items: end;
    padding: 14px 0 10px; border-bottom: 1px solid var(--line); }
  .row .who { padding-bottom: 4px; }
  .row .who .rank { font-family: "Space Mono", monospace; color: var(--muted); font-size: 11px; margin-right: 6px; }
  .row .who .name { font-weight: 700; font-size: 15px; display: inline; }
  .row .who .handle { display: block; color: var(--muted); font-family: "Space Mono", monospace; font-size: 11px; margin-top: 2px; }

  .row .bars { display: grid; grid-template-columns: repeat(31, 1fr);
    height: 64px; align-items: end; }
  .row .bars .col { display: flex; align-items: flex-end; justify-content: center;
    height: 100%; padding: 0 1px; position: relative; }
  .row .bars .col.we { background: var(--weekend); }
  .row .bars .col i { display: block; width: 100%; max-width: 14px; min-height: 0;
    background: var(--bar); transition: background .15s; }
  .row .bars .col i.warm { background: var(--warm); }
  .row .bars .col i.hot { background: var(--hot); }
  .row .bars .col:hover i { background: var(--hot); }

  .row .totals { text-align: right; font-family: "Space Mono", monospace; padding-bottom: 4px; }
  .row .totals .big { font-size: 22px; font-weight: 700; }
  .row .totals .big small { font-size: 12px; font-weight: 400; color: var(--muted); margin-left: 2px; }
  .row .totals .dist { display: block; font-size: 12px; color: var(--muted); margin-top: 2px; }
  .row .totals .peak { display: block; font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; margin-top: 2px; }

  .footer { display: flex; justify-content: space-between; margin-top: 30px; color: var(--muted);
    font-family: "Space Mono", monospace; font-size: 11px; text-transform: uppercase; letter-spacing: .12em; }
  .footer a { color: var(--ink); text-decoration: underline; text-decoration-thickness: 1px; }
  .legend { display: flex; align-items: center; gap: 14px; }
  .legend span { display: inline-flex; align-items: center; gap: 4px; }
  .legend i { display: inline-block; width: 12px; height: 12px; background: var(--bar); }
  .legend i.warm { background: var(--warm); }
  .legend i.hot { background: var(--hot); }
</style>
</head>
