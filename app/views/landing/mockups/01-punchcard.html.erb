<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>May is Bike Month 2025</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@300;500;700&display=swap" rel="stylesheet">
<%= render "landing/mockups/head_includes" %>
<style>
  :root {
    --purple-0: #f3edf8;
    --purple-1: #e8dbf1;
    --purple-2: #d0b7e3;
    --purple-3: #b994d4;
    --purple-4: #a170c6;
    --purple-5: #8a4cb8;
    --purple-6: #6e3d93;
    --purple-7: #532e6e;
    --purple-8: #371e4a;
    --purple-9: #1c0f25;

    --bg:      var(--purple-0);
    --surface: #ffffff;
    --line:    var(--purple-1);
    --muted:   var(--purple-3);
    --dim:     var(--purple-4);
    --fg:      var(--purple-9);
    --accent:  var(--purple-5);
    --accent-2: var(--purple-6);
    --cell-bg: var(--purple-1);
    --cell-1:  var(--purple-2);
    --cell-2:  var(--purple-3);
    --cell-3:  var(--purple-4);
    --cell-4:  var(--purple-5);
    --cell-5:  var(--purple-6);
    --bars-from: var(--purple-3);
    --bars-to:   var(--purple-5);
  }
  html.dark {
    --bg:      var(--purple-9);
    --surface: var(--purple-8);
    --line:    var(--purple-7);
    --muted:   var(--purple-4);
    --dim:     var(--purple-3);
    --fg:      var(--purple-0);
    --accent:  var(--purple-2);
    --accent-2: var(--purple-1);
    --cell-bg: var(--purple-7);
    --cell-1:  var(--purple-9);
    --cell-2:  var(--purple-8);
    --cell-3:  var(--purple-7);
    --cell-4:  var(--purple-6);
    --cell-5:  var(--purple-5);
    --bars-from: var(--purple-7);
    --bars-to:   var(--purple-5);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg);
    font-family: "IBM Plex Sans", system-ui, sans-serif; font-size: 13px; line-height: 1.45; }
  .wrap { max-width: 1340px; margin: 0 auto; padding: 32px 28px 80px; }

  header { display: grid; grid-template-columns: 1.4fr 1fr; gap: 36px; align-items: baseline;
    padding-bottom: 20px; margin-bottom: 28px; }
  header h1 { font-family: "IBM Plex Mono", monospace; font-weight: 500; font-size: 34px; letter-spacing: -0.5px; margin: 0; }
  header h1 b { color: var(--accent); font-weight: 700; }
  html.dark header h1 b { color: var(--muted); }
  header .meta { display: grid; grid-template-columns: repeat(4, auto); gap: 24px; justify-content: end; text-align: right; }
  header .meta .num { font-family: "IBM Plex Mono", monospace; font-size: 22px; color: var(--fg); font-weight: 500; }
  header .meta .label { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; margin-top: 2px; }
  @media (max-width: 1024px) {
    header { grid-template-columns: 1fr; gap: 18px; }
    header .meta { justify-content: start; text-align: left; }
  }

  .rules { margin-bottom: 56px; }
  .rules h4 { font-family: "IBM Plex Mono", monospace; font-size: 11px; font-weight: 500;
    text-transform: uppercase; letter-spacing: .14em; color: var(--muted);
    margin: 0 0 6px; text-align: left; }
  .rules ul { margin: 0; padding: 0; list-style: none; display: flex; flex-wrap: wrap;
    justify-content: flex-start; gap: 6px 22px; font-size: 13px; color: var(--dim); }
  @media (min-width: 640px) {
    .rules { display: grid; grid-template-columns: auto 1fr; column-gap: 24px; align-items: center; }
    .rules h4 { margin: 0; }
  }

  .ridge { margin-bottom: 6px; display: grid; grid-template-columns: 220px 1fr 110px;
    grid-template-rows: 56px 0; column-gap: 12px; row-gap: 0; align-items: end; }
  .ridge .ridge-label { grid-row: 2; grid-column: 1; align-self: start;
    font-family: "IBM Plex Mono", monospace; font-size: 11px; color: var(--muted);
    text-transform: uppercase; letter-spacing: .12em; text-align: right; padding-right: 4px;
    line-height: 1; }
  .ridge .bars { grid-row: 1; grid-column: 2;
    display: grid; grid-template-columns: repeat(31, 1fr); gap: 2px; height: 56px; align-items: end; }
  .ridge .bars i { display: block; background: linear-gradient(180deg, var(--bars-from), var(--bars-to)); border-radius: 1px; opacity: 0.9;
    cursor: default; }
  .ridge .bars i:hover { opacity: 1; }

  .axis { display: grid; grid-template-columns: 220px 1fr 110px; gap: 12px; align-items: center;
    border-bottom: 1px solid var(--line); padding: 6px 0; margin-bottom: 4px;
    color: var(--muted); font-family: "IBM Plex Mono", monospace; font-size: 11px; }
  .axis .days { display: grid; grid-template-columns: repeat(31, 1fr); gap: 2px; text-align: center;
    grid-column: 2; }
  .axis .days span.we { color: var(--muted); }

  .row { display: grid; grid-template-columns: 220px 1fr 110px; gap: 12px; align-items: center;
    padding: 9px 0; border-bottom: 1px solid var(--line); }
  .row .who { display: flex; align-items: center; gap: 8px; min-width: 0; }
  .row .who .strava { display: inline-flex; align-items: center; flex-shrink: 0; }
  .row .who .strava svg { width: 14px; height: 14px; display: block; opacity: .75; transition: opacity .15s; }
  .row .who .strava:hover svg { opacity: 1; }
  .row .who .rank { font-family: "IBM Plex Mono", monospace; color: var(--muted); font-size: 11px; width: 22px; text-align: right; flex-shrink: 0; }
  .row .who .name-block { display: flex; align-items: center; min-width: 0; }
  .row .who .name { color: var(--fg); font-weight: 500; }

  .row .punchcard { display: grid; grid-template-columns: repeat(31, 1fr); gap: 2px; height: 28px; }
  .row .punchcard .cell { background: transparent; border-radius: 2px; position: relative; }
  .row .punchcard .cell:not([data-l])::before,
  .row .punchcard .cell:not([data-l])::after {
    content: ""; position: absolute; left: 50%; top: 50%;
    width: 55%; height: 1.5px; background: #f9a8d4;
    border-radius: 1px;
  }
  .row .punchcard .cell:not([data-l])::before { transform: translate(-50%, -50%) rotate(45deg); }
  .row .punchcard .cell:not([data-l])::after  { transform: translate(-50%, -50%) rotate(-45deg); }
  .row .punchcard .cell[data-l="1"] { background: var(--cell-1); }
  .row .punchcard .cell[data-l="2"] { background: var(--cell-2); }
  .row .punchcard .cell[data-l="3"] { background: var(--cell-3); }
  .row .punchcard .cell[data-l="4"] { background: var(--cell-4); }
  .row .punchcard .cell[data-l="5"] { background: var(--cell-5); }
  .row .punchcard .cell[data-century]::after {
    content: "💯"; position: absolute; left: 50%; top: 50%;
    transform: translate(-50%, -50%); font-size: 14px; line-height: 1;
    pointer-events: none;
  }

  .row .punchcard .cell[data-l="3"] { box-shadow: 0 0 6px rgba(83,46,110,0.45); }
  .row .punchcard .cell[data-l="4"] { box-shadow: 0 0 10px rgba(110,61,147,0.6); }
  .row .punchcard .cell[data-l="5"] { box-shadow: 0 0 14px rgba(138,76,184,0.75); }

  .row .totals { text-align: right; font-family: "IBM Plex Mono", monospace; font-size: 12px; color: var(--dim); }
  .row .totals .big { color: var(--fg); font-size: 18px; font-weight: 500; }
  .row .totals .big b { color: var(--accent); font-weight: 700; }
  html.dark .row .totals .big b { color: var(--muted); }

  .footer { display: flex; justify-content: space-between; margin-top: 26px; color: var(--muted);
    font-family: "IBM Plex Mono", monospace; font-size: 11px; text-transform: uppercase; letter-spacing: .12em; }
  .footer a { color: var(--accent); text-decoration: none; }
  .footer a:hover { text-decoration: underline; }
  .legend-block { display: flex; align-items: center; gap: 6px; }
  .legend-block .scale { display: inline-grid; grid-template-columns: repeat(5, 12px); gap: 2px; }
  .legend-block .scale i { display: block; height: 12px; border-radius: 2px; }
  .legend-block .scale i:nth-child(1) { background: var(--cell-1); }
  .legend-block .scale i:nth-child(2) { background: var(--cell-2); }
  .legend-block .scale i:nth-child(3) { background: var(--cell-3); }
  .legend-block .scale i:nth-child(4) { background: var(--cell-4); }
  .legend-block .scale i:nth-child(5) { background: var(--cell-5); }
</style>
</head>
<body>
<%= render(UserDropdown::Component.new(current_user:)) %>
<%= render "landing/mockups/punchcard_body" %>
</body>
</html>
