<!DOCTYPE html>

<html>
  <head>
    <title><%= page_title %></title>

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="May is Bike Month">
    <meta name="mobile-web-app-capable" content="yes">

    <%= tag.meta name: "honeybadger-api-key", content: ENV["HONEYBADGER_API_KEY"] %>
    <%= tag.meta name: "honeybadger-environment", content: Rails.env %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if Rails.env.development? %>
      <link href="/favicon-dev.ico" rel="icon" sizes="192x192">
      <%= stylesheet_link_tag :app %>
      <%= hotwire_livereload_tags %>
    <% else %>
      <link href="/favicon.ico" rel="icon" sizes="192x192">
      <link
        rel="apple-touch-icon-precomposed apple-touch-icon"
        href="/apple-touch-icon.png"
      >
      <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <% end %>

    <%= javascript_importmap_tags %>

    <% unless display_dev_info? %>
      <style>
        .only-dev-visible {display: none !important;}
      </style>
    <% end %>
  </head>

  <body class="bg-white antialiased">
    <!--

  Source Code:

  github.com/MayIsBikeMonth/may_is_bike_month

  -->
    <ul
      class="
        relative z-10 flex items-center gap-4 px-2 lg:px-4 justify-end mt-1
        mb-2
      "
    >
      <% if current_user.blank? %>
        <li>
          <%= button_to "Sign in", user_strava_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "twlink" %>
        </li>
      <% elsif in_admin? %>
        <span class="hidden sm:inline-block ml-2 text-lg font-semibold">
          May Is Bike Month Admin
        </span>
        <%= active_link "Competition Users", admin_competition_users_path, class: "twlink ml-2", match_controller: true %>
        <%= active_link "Competitions", admin_competitions_path, class: "twlink ml-2", match_controller: true %>
        <%= link_to "Exit", user_root_url, class: "twlink ml-auto less-strong" %>
      <% else %>
        <%= render(UserSettingsModal::Component.new(current_user:)) do |settings_modal| %>
          <% settings_modal.with_trigger do %>
            <div class="relative inline-block" data-controller="dropdown">
              <button
                type="button"
                class="
                  flex items-center gap-1.5 text-sm font-medium text-gray-700
                  dark:text-gray-300 hover:text-gray-900 dark:hover:text-white
                  cursor-pointer
                "
                aria-expanded="false"
                data-action="click->dropdown#toggle"
                data-dropdown-target="button"
                id="user-menu-button"
              >
                <div
                  class="
                    w-7 h-7 rounded-full bg-blue-600 flex items-center
                    justify-center text-white text-xs font-medium
                  "
                >
                  <%= current_user.display_name.first.upcase %>
                </div>

                <%= current_user.display_name %>

                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </button>

              <div
                class="
                  hidden bg-white dark:bg-gray-800 rounded-lg shadow-lg border
                  border-gray-200 dark:border-gray-700 min-w-44 z-50
                "
                data-dropdown-target="menu"
                data-dropdown-placement-value="bottom-end"
              >
                <ul
                  class="dropdown-menu py-1 list-none"
                  aria-labelledby="user-menu-button"
                >
                  <li>
                    <button
                      type="button"
                      data-action="click->modal#open click->dropdown#toggle"
                    >
                      Settings
                    </button>
                  </li>

                  <% if current_user.admin_access? %>
                    <li><%= link_to "Admin", admin_root_path %></li>
                  <% end %>

                  <li>
                    <hr class="my-1 border-gray-200 dark:border-gray-700">
                  </li>

                  <li>
                    <%= button_to "Logout", destroy_user_session_path, method: :delete, data: {turbo: false} %>
                  </li>
                </ul>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </ul>

    <%= render_flash_messages %>

    <div class="<%= @skip_wrapper_class ? "" : "wrapper-class" %>">
      <%= yield %>
    </div>

    <!-- Google tag (gtag.js) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-63Y0BHVCS8"
    ></script>

    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-63Y0BHVCS8');
    </script>
  </body>
</html>
