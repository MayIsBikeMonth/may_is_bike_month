<!DOCTYPE html>

<html>
  <head>
    <title><%= page_title %></title>

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="May is Bike Month">
    <meta name="mobile-web-app-capable" content="yes">

    <%= tag.meta name: "honeybadger-api-key", content: ENV["HONEYBADGER_API_KEY"] %>
    <%= tag.meta name: "honeybadger-environment", content: Rails.env %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if Rails.env.development? %>
      <link href="/favicon-dev.ico" rel="icon" sizes="192x192">
      <%= stylesheet_link_tag :app %>
      <%= hotwire_livereload_tags %>
    <% else %>
      <link href="/favicon.ico" rel="icon" sizes="192x192">
      <link
        rel="apple-touch-icon-precomposed apple-touch-icon"
        href="/apple-touch-icon.png"
      >
      <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <% end %>

    <%= javascript_importmap_tags %>

    <% unless display_dev_info? %>
      <style>
        .only-dev-visible {display: none !important;}
      </style>
    <% end %>
  </head>

  <body class="bg-white antialiased">
    <!--

  Source Code:

  github.com/MayIsBikeMonth/may_is_bike_month

  -->
    <ul
      class="
        relative z-10 flex items-center gap-4 px-2 lg:px-4 justify-end mt-1
        mb-2
      "
    >
      <% if current_user.blank? %>
        <li>
          <%= button_to "Sign in", user_strava_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "twlink" %>
        </li>
      <% elsif in_admin? %>
        <span class="hidden sm:inline-block ml-2 text-lg font-semibold">
          May Is Bike Month Admin
        </span>
        <%= active_link "Competition Users", admin_competition_users_path, class: "twlink ml-2", match_controller: true %>
        <%= active_link "Competitions", admin_competitions_path, class: "twlink ml-2", match_controller: true %>
        <%= link_to "Exit", user_root_url, class: "twlink ml-auto less-strong" %>
      <% else %>
        <li data-controller="modal">
          <div class="relative inline-block" data-controller="dropdown">
            <button
              type="button"
              class="
                flex items-center gap-1.5 text-sm font-medium text-gray-700
                dark:text-gray-300 hover:text-gray-900 dark:hover:text-white
                cursor-pointer
              "
              aria-expanded="false"
              data-action="click->dropdown#toggle"
              data-dropdown-target="button"
              id="user-menu-button"
            >
              <div
                class="
                  w-7 h-7 rounded-full bg-blue-600 flex items-center
                  justify-center text-white text-xs font-medium
                "
              >
                <%= current_user.display_name.first.upcase %>
              </div>

              <%= current_user.display_name %>

              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>

            <div
              class="
                hidden bg-white dark:bg-gray-800 rounded-lg shadow-lg border
                border-gray-200 dark:border-gray-700 min-w-44 z-50
              "
              data-dropdown-target="menu"
              data-dropdown-placement-value="bottom-end"
            >
              <ul
                class="dropdown-menu py-1 list-none"
                aria-labelledby="user-menu-button"
              >
                <li>
                  <button
                    type="button"
                    data-action="click->modal#open click->dropdown#toggle"
                  >
                    Settings
                  </button>
                </li>

                <% if current_user.admin_access? %>
                  <li><%= link_to "Admin", admin_root_path %></li>
                <% end %>

                <li>
                  <hr class="my-1 border-gray-200 dark:border-gray-700">
                </li>

                <li>
                  <%= button_to "Logout", destroy_user_session_path, method: :delete, data: {turbo: false} %>
                </li>
              </ul>
            </div>
          </div>

          <dialog
            data-modal-target="dialog"
            data-action="click->modal#backdropClick keydown->modal#handleKeydown"
            class="
              backdrop:bg-black/50 backdrop:backdrop-blur-sm bg-transparent
              p-0 m-auto max-w-lg w-full open:flex open:items-center
              open:justify-center
            "
          >
            <div
              class="
                bg-white dark:bg-gray-800 rounded-xl shadow-xl w-full mx-4
                overflow-hidden
              "
            >
              <div
                class="
                  flex items-center justify-between px-5 py-4 border-b
                  border-gray-200 dark:border-gray-700
                "
              >
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                  Settings
                </h3>

                <button
                  type="button"
                  data-action="click->modal#close"
                  class="
                    text-gray-400 hover:text-gray-600
                    dark:hover:text-gray-300 cursor-pointer
                  "
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M6 18L18 6M6 6l12 12"
                    />
                  </svg>
                </button>
              </div>

              <div class="px-5 py-4">
                <div class="space-y-6">
                  <%# Theme %>
                  <div
                    data-controller="theme"
                    data-theme-url-value="<%= account_path %>"
                    data-theme-current-value="<%= current_user.try(:theme).presence || "system" %>"
                  >
                    <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-3">
                      Theme
                    </h4>

                    <div class="flex gap-3">
                      <button
                        data-action="click->theme#select"
                        data-theme-target="option"
                        data-theme="theme_light"
                        class="
                          flex-1 flex flex-col items-center gap-2 p-3
                          rounded-lg border border-gray-200
                          dark:border-gray-600 hover:border-blue-400
                          transition-all cursor-pointer
                        "
                      >
                        <svg
                          class="w-6 h-6 text-yellow-500"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zm11.394-5.834a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zm5.834-1.166a.75.75 0 00-1.06 1.06l1.59 1.591a.75.75 0 101.061-1.06l-1.59-1.591zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zm.166 5.834a.75.75 0 001.06 1.06l1.591-1.59a.75.75 0 00-1.06-1.061l-1.591 1.59zm-.412-11.668a.75.75 0 10-1.06 1.06l1.59 1.591a.75.75 0 001.061-1.06l-1.59-1.591zM18 12a.75.75 0 01.75-.75H21a.75.75 0 010 1.5h-2.25A.75.75 0 0118 12z"
                          />
                        </svg>

                        <span class="text-xs text-gray-600 dark:text-gray-400">
                          Light
                        </span>
                      </button>

                      <button
                        data-action="click->theme#select"
                        data-theme-target="option"
                        data-theme="theme_dark"
                        class="
                          flex-1 flex flex-col items-center gap-2 p-3
                          rounded-lg border border-gray-200
                          dark:border-gray-600 hover:border-blue-400
                          transition-all cursor-pointer
                        "
                      >
                        <svg
                          class="w-6 h-6 text-indigo-400"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z"
                            clip-rule="evenodd"
                          />
                        </svg>

                        <span class="text-xs text-gray-600 dark:text-gray-400">
                          Dark
                        </span>
                      </button>

                      <button
                        data-action="click->theme#select"
                        data-theme-target="option"
                        data-theme="system"
                        class="
                          flex-1 flex flex-col items-center gap-2 p-3
                          rounded-lg border border-gray-200
                          dark:border-gray-600 hover:border-blue-400
                          transition-all cursor-pointer
                        "
                      >
                        <svg
                          class="w-6 h-6 text-gray-500"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M2.25 5.25a3 3 0 013-3h13.5a3 3 0 013 3V15a3 3 0 01-3 3h-5.379l1.94 1.94a.75.75 0 01-1.06 1.06L12 18.75l-2.251 2.25a.75.75 0 01-1.06-1.06L10.629 18H5.25a3 3 0 01-3-3V5.25zm1.5 0V15a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5V5.25a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5z"
                            clip-rule="evenodd"
                          />
                        </svg>

                        <span class="text-xs text-gray-600 dark:text-gray-400">
                          System
                        </span>
                      </button>
                    </div>
                  </div>

                  <%# Unit preference %>
                  <div data-controller="unit-preference">
                    <h4 class="text-sm font-medium text-gray-900 dark:text-white mb-3">
                      Units
                    </h4>

                    <div class="flex gap-3">
                      <button
                        data-action="click->unit-preference#select"
                        data-unit="imperial"
                        data-unit-preference-target="option"
                        class="
                          flex-1 p-3 rounded-lg border border-gray-200
                          dark:border-gray-600 hover:border-blue-400
                          transition-all text-center cursor-pointer
                        "
                      >
                        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                          Imperial
                        </span>

                        <span class="block text-xs text-gray-500 dark:text-gray-400 mt-1">
                          miles, feet
                        </span>
                      </button>

                      <button
                        data-action="click->unit-preference#select"
                        data-unit="metric"
                        data-unit-preference-target="option"
                        class="
                          flex-1 p-3 rounded-lg border border-gray-200
                          dark:border-gray-600 hover:border-blue-400
                          transition-all text-center cursor-pointer
                        "
                      >
                        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                          Metric
                        </span>

                        <span class="block text-xs text-gray-500 dark:text-gray-400 mt-1">
                          km, meters
                        </span>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </dialog>
        </li>
      <% end %>
    </ul>

    <%= render_flash_messages %>

    <div class="<%= @skip_wrapper_class ? "" : "wrapper-class" %>">
      <%= yield %>
    </div>

    <!-- Google tag (gtag.js) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-63Y0BHVCS8"
    ></script>

    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-63Y0BHVCS8');
    </script>
  </body>
</html>
