<% if @competition.legacy? %>
  <%= render(Leaderboard::LegacyCompetitionWrapper::Component.new(
    competition: @competition,
    competition_users: @competition_users,
    competitions: @competitions
  )) %>
<% else %>
  <%= render(Leaderboard::PunchcardWrapper::Component.new(
    competition: @competition,
    competition_users: @competition_users,
    competitions: @competitions
  )) %>
<% end %>
