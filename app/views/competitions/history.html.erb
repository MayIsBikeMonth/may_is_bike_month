<div class="pt-8 pb-20">
  <div class="max-w-[1340px] mx-auto wrapper-padding">
    <header
      class="
        flex items-baseline justify-between flex-wrap gap-x-6 gap-y-4 pb-5
        mb-7
      "
    >
      <h1
        class="
          font-mono font-medium text-[34px] tracking-[-0.5px] m-0 text-black
          dark:text-white
        "
      >
        MIBM <b class="font-bold">history</b>
      </h1>

      <%= form_with url: history_path,
            method: :get,
            data: { controller: "auto-submit" },
            class: "max-w-[520px]" do %>
        <%= combobox_tag "users",
              hw_combobox_options(@selectable_users, value: :slug, display: :display_name),
              id: "history-users-combobox",
              multiselect_chip_src: history_user_chips_path,
              value: @selected_users.map(&:slug).join(","),
              placeholder: "View someone specific",
              input: { aria: { label: "Compare riders" } } %>
      <% end %>
    </header>
  </div>

  <%= render(CompetitionHistory::Component.new(competitions: @competitions, selected_users: @selected_users)) %>

  <div class="max-w-[1340px] mx-auto wrapper-padding">
    <%= render(Leaderboard::OtherCompetitionLinks::Component.new(competitions: @competitions, current_competition: nil)) %>
  </div>
</div>
