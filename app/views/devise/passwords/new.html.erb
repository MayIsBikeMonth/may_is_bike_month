<%= render(UI::Card::Component.new) do %>
  <%= render(UI::Header::Component.new(text: "Forgot your password?")) %>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: {method: :post}, builder: MayIsBikeMonthFormBuilder) do |f| %>
    <%= render(UI::AlertForErrors::Component.new(object: resource)) %>

    <%= render(Form::Group::Component.new(form_builder: f, attribute: :email, kind: :email_field, html_options: {autofocus: true, autocomplete: "email"})) %>

    <%= render(UI::Button::Component.new(text: "Send me reset password instructions", color: :primary, kind: :submit)) %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
