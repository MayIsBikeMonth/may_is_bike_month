<%= render(UI::Card::Component.new) do %>
  <%= render(UI::Header::Component.new(text: "Log in")) %>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), builder: MayIsBikeMonthFormBuilder) do |f| %>
    <%= render(Form::Group::Component.new(form_builder: f, attribute: :email, kind: :email_field, html_options: {autofocus: true, autocomplete: "email"})) %>

    <div class="mb-4">
      <%= f.label :password, class: Form::Group::Component::LABEL_CLASSES %>
      <%= f.password_field :password, autocomplete: "current-password", class: Form::Input::Component::INPUT_CLASSES %>
    </div>

    <div class="flex items-center mb-4">
      <%= f.check_box :remember_me, class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600" %>
      <%= f.label :remember_me, class: "ms-2 text-sm font-medium text-gray-900 dark:text-gray-300" %>
    </div>

    <%= render(UI::Button::Component.new(text: "Log in", color: :primary, kind: :submit)) %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
