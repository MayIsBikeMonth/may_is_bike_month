<% grid_style = "--legacy-grid-desktop: 40px minmax(120px, 1fr) repeat(#{periods.size}, minmax(68px, 1fr)) 110px; --legacy-grid-mobile: 40px minmax(120px, 1fr) 110px repeat(#{periods.size}, minmax(68px, 1fr));" %>
<% grid_classes = "grid [grid-template-columns:var(--legacy-grid-mobile)] lg:[grid-template-columns:var(--legacy-grid-desktop)]" %>

<div
  class="max-w-[1340px] mx-auto pt-8 wrapper-padding pb-20"
  data-controller="legacy-activities"
>
  <%= render(Punchcard::Header::Component.new(
    competition: @competition,
    rider_count: @competition_users.size,
    distance_meters: total_distance_meters,
    elevation_meters: total_elevation_meters
  )) %>

  <%= render(Punchcard::Rules::Component.new(competition: @competition)) %>

  <main
    class="wrapper-padding-overflow overflow-x-auto"
    style="<%= grid_style %>"
  >
    <div class="min-w-[720px]">
      <div class="flex items-center gap-4 mb-4 text-[12px]">
        <button
          type="button"
          class="
            text-purple-300 dark:text-purple-400 hover:text-purple-500
            dark:hover:text-purple-200 hover:underline cursor-pointer
            aria-pressed:text-purple-500 dark:aria-pressed:text-purple-200
            aria-pressed:underline
          "
          aria-pressed="false"
          data-action="click->legacy-activities#showAll"
          data-legacy-activities-target="showAllBtn"
        >
          Show all activities
        </button>

        <button
          type="button"
          class="
            hidden text-purple-300 dark:text-purple-400 hover:text-purple-500
            dark:hover:text-purple-200 hover:underline cursor-pointer
          "
          data-action="click->legacy-activities#hideAll"
          data-legacy-activities-target="hideAllBtn"
        >
          Hide all activities
        </button>
      </div>

      <div
        class="
          <%= grid_classes %>
          gap-3 items-end pb-2 mb-2 border-b border-purple-100
          dark:border-purple-700 font-mono text-[11px] uppercase tracking-[0.1em]
          text-purple-300 dark:text-purple-400
        "
      >
        <span></span>
        <span></span>

        <% periods.each do |period| %>
          <span class="text-right"><%= period_label(period) %></span>
        <% end %>

        <span class="text-right max-lg:col-start-3 max-lg:row-start-1">
          Total
        </span>
      </div>

      <% @competition_users.each_with_index do |competition_user, index| %>
        <% entries = period_entries(competition_user) %>
        <% activities = activities_by_date(competition_user) %>
        <% user_slug = competition_user.user.slug %>

        <div class="border-b border-purple-100 dark:border-purple-700 py-3">
          <div class="<%= grid_classes %> gap-3 items-baseline">
            <span
              class="
                font-mono font-bold text-purple-300 dark:text-purple-400
                text-[13px]
              "
            >
              <%= index + 1 %>
            </span>

            <div class="flex items-center gap-2 min-w-0">
              <% if competition_user.user.strava_id.present? %>
                <a
                  class="
                    inline-flex items-center shrink-0 opacity-75
                    hover:opacity-100 transition-opacity
                  "
                  href="<%= competition_user.user.strava_user_url %>"
                  target="_blank"
                  rel="noopener"
                  title="View on Strava"
                >
                  <%= helpers.image_tag("strava_logo.svg", alt: "Strava", class: "w-3.5 h-3.5 block") %>
                </a>
              <% end %>

              <% if activities.any? %>
                <button
                  type="button"
                  class="
                    text-purple-900 dark:text-purple-0 font-medium text-left
                    truncate cursor-pointer outline-none underline decoration-1
                    decoration-transparent hover:decoration-current
                    aria-pressed:decoration-current aria-pressed:decoration-2
                    focus-visible:decoration-current
                  "
                  aria-pressed="false"
                  data-action="click->legacy-activities#toggleUser"
                  data-legacy-activities-target="userButton"
                  data-user-slug="<%= user_slug %>"
                >
                  <%= competition_user.display_name %>
                </button>
              <% else %>
                <span class="text-purple-900 dark:text-purple-0 font-medium truncate">
                  <%= competition_user.display_name %>
                </span>
              <% end %>
            </div>

            <% entries.each do |entry| %>
              <div
                class="
                  text-right font-mono text-[12px] text-purple-400
                  dark:text-purple-300
                "
              >
                <span class="unit-imperial">
                  <%= number_display(meters_to_miles(entry["distance"].to_f), round_to: 1) %>
                  mi
                </span>

                <span class="unit-metric hidden">
                  <%= number_display(entry["distance"].to_f / 1000.0, round_to: 1) %>
                  km
                </span>

                <br>

                <span class="opacity-40">
                  <span class="unit-imperial">
                    <%= number_display(meters_to_feet(entry["elevation"].to_f)) %>
                    ft
                  </span>

                  <span class="unit-metric hidden">
                    <%= number_display(entry["elevation"].to_f) %> m
                  </span>
                </span>
              </div>
            <% end %>

            <div
              class="
                text-right font-mono text-[12px] text-purple-400
                dark:text-purple-300 max-lg:col-start-3 max-lg:row-start-1
              "
            >
              <span class="text-purple-900 dark:text-purple-0 text-[16px] font-medium">
                <span class="unit-imperial">
                  <%= number_display(meters_to_miles(competition_user.distance_meters), round_to: 1) %>
                  mi
                </span>

                <span class="unit-metric hidden">
                  <%= number_display(competition_user.distance_meters / 1000.0, round_to: 1) %>
                  km
                </span>
              </span>

              <br>

              <span class="opacity-40">
                <span class="unit-imperial">
                  <%= number_display(meters_to_feet(competition_user.elevation_meters)) %>
                  ft
                </span>

                <span class="unit-metric hidden">
                  <%= number_display(competition_user.elevation_meters) %> m
                </span>
              </span>
            </div>
          </div>

          <% if activities.any? %>
            <div
              class="
                hidden! columns-1 md:columns-2 lg:columns-3
                [column-gap:1.5rem] text-[12px] mt-3
              "
              data-legacy-activities-target="activities"
              data-user-slug="<%= user_slug %>"
            >
              <% activities.each do |date_string, day_activities| %>
                <div class="pl-9 -indent-9 break-inside-avoid pb-1">
                  <span class="opacity-50 font-mono text-[11px]">
                    <%= short_date(date_string) %>
                  </span>

                  <%= safe_join(day_activities.map { |a| activity_link(a) }, ", ") %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </main>

  <% if @competitions.many? %>
    <%= render(OtherCompetitionLinks::Component.new(
      competitions: @competitions,
      current_competition: @competition
    )) %>
  <% end %>
</div>
