<div class="-mx-4 mb-4 overflow-x-scroll px-4 pb-3">
  <table class="<%= table_classes %>">
    <thead
      class="
        dark:bg-gray-700 bg-gray-50 text-sm
      "
    >
      <tr>
        <% @columns.each_with_index do |col, i| %>
          <th class="<%= th_classes(col, i) %>">
            <% if col.sortable.present? %>
              <%= render_sortable(col.sortable) %>
            <% else %>
              <%= col.label %>
            <% end %>
          </th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% @records.each_with_index do |record, row_index| %>
        <% cache_if(@cache_key, [@cache_key, record]) do %>
          <% last_row = row_index == @records.length - 1 %>
          <tr
            class="
              even:bg-gray-100 odd:bg-white dark:even:bg-gray-800
              dark:odd:bg-gray-900
            "
          >
            <% @columns.each_with_index do |col, i| %>
              <td class="<%= td_classes(col, i, last_row:) %>">
                <%= capture { instance_exec(record, &col.block) } %>
              </td>
            <% end %>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
