<div
  class="max-w-[1340px] mx-auto pt-8 wrapper-padding pb-20"
  data-controller="legacy-activities"
>
  <%= render(Leaderboard::Header::Component.new(
    competition: @competition,
    rider_count: @competition_users.size,
    distance_meters: total_distance_meters,
    elevation_meters: total_elevation_meters
  )) %>

  <%= render(Leaderboard::Rules::Component.new(competition: @competition)) %>

  <main
    class="wrapper-padding-overflow overflow-x-auto"
    style="<%= grid_style %>"
  >
    <div class="min-w-[720px]">
      <% if any_activities? %>
        <div class="flex items-center gap-4 mb-4 text-[12px]">
          <button
            type="button"
            class="
              text-purple-300 dark:text-purple-400 hover:text-purple-500
              dark:hover:text-purple-200 hover:underline cursor-pointer
              aria-pressed:text-purple-500 dark:aria-pressed:text-purple-200
              aria-pressed:underline
            "
            aria-pressed="false"
            data-action="click->legacy-activities#showAll"
            data-legacy-activities-target="showAllBtn"
          >
            Show all activities
          </button>

          <button
            type="button"
            class="
              hidden text-purple-300 dark:text-purple-400 hover:text-purple-500
              dark:hover:text-purple-200 hover:underline cursor-pointer
            "
            data-action="click->legacy-activities#hideAll"
            data-legacy-activities-target="hideAllBtn"
          >
            Hide all activities
          </button>
        </div>
      <% end %>

      <div
        class="
          <%= grid_classes %>
          gap-3 items-end pb-2 mb-2 border-b border-purple-100
          dark:border-purple-700 font-mono text-[11px] uppercase tracking-[0.1em]
          text-purple-300 dark:text-purple-400
        "
      >
        <span></span>
        <span></span>

        <% periods.each do |period| %>
          <span class="text-right"><%= period_label(period) %></span>
        <% end %>

        <span class="text-right max-lg:col-start-3 max-lg:row-start-1">
          Total
        </span>
      </div>

      <% @competition_users.each_with_index do |competition_user, index| %>
        <%= render(Leaderboard::LegacyCompetitionUserRow::Component.new(
          competition_user:,
          competition: @competition,
          rank: index + 1
        )) %>
      <% end %>
    </div>
  </main>

  <% if @competitions.many? %>
    <%= render(Leaderboard::OtherCompetitionLinks::Component.new(
      competitions: @competitions,
      current_competition: @competition
    )) %>
  <% end %>
</div>
