<div
  class="border-b border-purple-100 dark:border-purple-700 py-3"
  data-user-slug="<%= user_slug %>"
>
  <div class="<%= grid_classes %> gap-3 items-center">
    <span class="font-mono font-bold text-purple-300 dark:text-purple-400 text-[13px]">
      <%= @rank %>
    </span>

    <div class="flex items-center gap-2 min-w-0">
      <% if @competition_user.user.strava_id.present? %>
        <a
          class="
            inline-flex items-center shrink-0 opacity-75 hover:opacity-100
            transition-opacity
          "
          href="<%= @competition_user.user.strava_user_url %>"
          target="_blank"
          rel="noopener"
          title="View on Strava"
        >
          <%= helpers.image_tag("strava_logo.svg", alt: "Strava", class: "w-3.5 h-3.5 block") %>
        </a>
      <% end %>

      <% if has_activities? %>
        <button
          type="button"
          class="
            text-purple-900 dark:text-purple-0 font-medium text-left truncate
            cursor-pointer outline-none underline decoration-1
            decoration-transparent hover:decoration-current
            aria-pressed:decoration-current aria-pressed:decoration-2
            focus-visible:decoration-current
          "
          aria-pressed="false"
          data-action="click->legacy-activities#toggleUser"
          data-legacy-activities-target="userButton"
          data-user-slug="<%= user_slug %>"
        >
          <%= @competition_user.display_name %>
        </button>
      <% else %>
        <span class="text-purple-900 dark:text-purple-0 font-medium truncate">
          <%= @competition_user.display_name %>
        </span>
      <% end %>
    </div>

    <% period_entries.each do |entry| %>
      <div
        class="
          text-right font-mono text-[12px] text-purple-400
          dark:text-purple-300
        "
      >
        <span class="unit-imperial">
          <%= number_display(meters_to_miles(entry["distance"].to_f), round_to: 1) %>
          mi
        </span>

        <span class="unit-metric hidden">
          <%= number_display(entry["distance"].to_f / 1000.0, round_to: 1) %> km
        </span>

        <br>

        <span class="opacity-40">
          <span class="unit-imperial">
            <%= number_display(meters_to_feet(entry["elevation"].to_f)) %> ft
          </span>

          <span class="unit-metric hidden">
            <%= number_display(entry["elevation"].to_f) %> m
          </span>
        </span>
      </div>
    <% end %>

    <div
      class="
        text-right font-mono text-[12px] text-purple-400 dark:text-purple-300
        max-lg:col-start-3 max-lg:row-start-1
      "
    >
      <span class="text-purple-900 dark:text-purple-0 text-[16px] font-medium">
        <span class="unit-imperial">
          <%= number_display(meters_to_miles(@competition_user.distance_meters), round_to: 1) %>
          mi
        </span>

        <span class="unit-metric hidden">
          <%= number_display(@competition_user.distance_meters / 1000.0, round_to: 1) %>
          km
        </span>
      </span>

      <br>

      <span class="opacity-40">
        <span class="unit-imperial">
          <%= number_display(meters_to_feet(@competition_user.elevation_meters)) %>
          ft
        </span>

        <span class="unit-metric hidden">
          <%= number_display(@competition_user.elevation_meters) %> m
        </span>
      </span>
    </div>
  </div>

  <% if has_activities? %>
    <%= render(Leaderboard::UserActivitiesForDateWrapper::Component.new(
      competition_user: @competition_user, competition: @competition
    )) %>
  <% end %>
</div>
