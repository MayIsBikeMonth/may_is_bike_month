<ul class="relative z-10 flex items-center gap-4 px-2 lg:px-4 justify-end mt-1 mb-2">
  <% if !signed_in? %>
    <li>
      <%= helpers.button_to "Sign in", helpers.user_strava_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "twlink" %>
    </li>
  <% elsif admin_view? %>
    <span class="hidden sm:inline-block ml-2 text-lg font-semibold">
      May Is Bike Month Admin
    </span>
    <%= helpers.active_link "Competition Users", helpers.admin_competition_users_path, class: "twlink ml-2", match_controller: true %>
    <%= helpers.active_link "Competitions", helpers.admin_competitions_path, class: "twlink ml-2", match_controller: true %>
    <%= helpers.link_to "Exit", helpers.user_root_url, class: "twlink ml-auto less-strong" %>
  <% else %>
    <%= render(UserSettingsModal::Component.new(current_user: @current_user)) do |settings_modal| %>
      <% settings_modal.with_trigger do %>
        <div class="relative inline-block" data-controller="dropdown">
          <button
            type="button"
            class="
              flex items-center gap-1.5 text-sm font-medium text-gray-700
              dark:text-gray-300 hover:text-gray-900 dark:hover:text-white
              cursor-pointer
            "
            aria-expanded="false"
            data-action="click->dropdown#toggle"
            data-dropdown-target="button"
            id="user-menu-button"
          >
            <div
              class="
                w-7 h-7 rounded-full bg-blue-600 flex items-center
                justify-center text-white text-xs font-medium
              "
            >
              <%= @current_user.display_name.first.upcase %>
            </div>

            <%= @current_user.display_name %>

            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </button>

          <div
            class="
              hidden bg-white dark:bg-gray-800 rounded-lg shadow-lg border
              border-gray-200 dark:border-gray-700 min-w-44 z-50
            "
            data-dropdown-target="menu"
            data-dropdown-placement-value="bottom-end"
          >
            <ul
              class="dropdown-menu py-1 list-none"
              aria-labelledby="user-menu-button"
            >
              <li>
                <button
                  type="button"
                  data-action="click->modal#open click->dropdown#toggle"
                  class="flex items-center gap-2"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7 7 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a7 7 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a7 7 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a7 7 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z"
                    />

                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                  Settings
                </button>
              </li>

              <% if admin_access? %>
                <li><%= helpers.link_to "Admin", helpers.admin_root_path %></li>
              <% end %>

              <li>
                <hr class="my-1 border-gray-200 dark:border-gray-700">
              </li>

              <li>
                <%= helpers.button_to "Logout", helpers.destroy_user_session_path, method: :delete, data: {turbo: false} %>
              </li>
            </ul>
          </div>
        </div>
      <% end %>
    <% end %>
  <% end %>
</ul>
