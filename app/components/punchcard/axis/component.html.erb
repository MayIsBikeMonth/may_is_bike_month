<div class="grid grid-cols-[220px_1fr_110px] gap-3 items-center border-b border-purple-100 dark:border-purple-700 py-1.5 mb-1 text-purple-300 dark:text-purple-400 font-mono text-[11px]">
  <div></div>
  <div class="punchcard-axis-days grid grid-cols-[repeat(31,1fr)] gap-0.5 text-center col-start-2">
    <% day_entries.each do |entry| %>
      <span class="<%= "we text-purple-300 dark:text-purple-400" if entry[:weekend] %>"><%= entry[:day] %></span>
    <% end %>
  </div>
  <div></div>
</div>
