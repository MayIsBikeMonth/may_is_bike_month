<div class="border-b border-purple-100 dark:border-purple-700 py-[9px]">
  <div class="grid grid-cols-[220px_1fr_110px] gap-3 items-center">
    <div class="flex items-center gap-2 min-w-0">
      <span class="font-mono text-purple-300 dark:text-purple-400 text-[11px] w-[22px] text-right shrink-0"><%= format("%02d", @rank) %></span>
      <a class="inline-flex items-center shrink-0 opacity-75 hover:opacity-100 transition-opacity" href="<%= strava_url %>" target="_blank" rel="noopener" title="View on Strava">
        <%= helpers.image_tag("strava_logo.svg", alt: "Strava", class: "w-3.5 h-3.5 block") %>
      </a>
      <div class="flex items-center min-w-0">
        <button type="button"
          class="text-purple-900 dark:text-purple-0 font-medium text-left cursor-pointer outline-none underline decoration-1 decoration-transparent hover:decoration-current aria-pressed:decoration-current aria-pressed:decoration-2 focus-visible:decoration-current"
          aria-pressed="false"
          data-action="click->punch#toggleUser"
          data-punch-target="userButton"
          data-user-slug="<%= user_slug %>">
          <%= @competition_user.display_name %>
        </button>
      </div>
    </div>

    <div class="grid grid-cols-[repeat(31,1fr)] gap-0.5 h-7">
      <% @period_date_strings.each do |date_string| %>
        <%= render(Punchcard::UserPunch::Component.new(
          date_string:,
          distance_meters: distance_meters_on(date_string),
          competition: @competition,
          punch_id: "#{user_slug}-#{date_string}",
          user_slug:
        )) %>
      <% end %>
    </div>

    <div class="text-right font-mono text-[12px] text-purple-400 dark:text-purple-300">
      <span class="text-purple-900 dark:text-purple-0 text-[18px] font-medium">
        <b class="text-purple-500 dark:text-purple-400 font-bold"><%= days_count %></b><span class="opacity-40">/<%= total_days %></span>
      </span><br>
      <span class="unit-imperial"><%= number_with_delimiter(total_miles.round(1)) %> mi</span>
      <span class="unit-metric hidden"><%= number_with_delimiter(total_km.round(1)) %> km</span>
      <br>
      <span class="opacity-40">
        <span class="unit-imperial"><%= "%.1f" % (total_feet / 1000.0) %>k ft</span>
        <span class="unit-metric hidden"><%= "%.1f" % (total_meters / 1000.0) %>k m</span>
      </span>
    </div>
  </div>

  <div class="flex flex-wrap gap-x-3 gap-t-2 pb-2 px-2 text-[12px]">
    <% activities_by_date.each do |date_string, activities| %>
      <%= render(Punchcard::UserActivitiesForDate::Component.new(
        date_string:,
        activities:,
        punch_id: "#{user_slug}-#{date_string}",
        competition_year: @competition.year
      )) %>
    <% end %>
  </div>
</div>
