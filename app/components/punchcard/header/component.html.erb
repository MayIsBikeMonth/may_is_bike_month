<% meta_num_class = "font-mono text-[22px] font-medium" %>
<% meta_label_class = "text-purple-300 dark:text-purple-400 text-[10px] uppercase tracking-[0.12em] mt-0.5 whitespace-nowrap" %>

<header
  class="
    grid grid-cols-[1.4fr_1fr] gap-9 items-baseline pb-5 mb-7
    max-lg:grid-cols-1 max-lg:gap-[18px]
  "
>
  <div>
    <h1 class="font-mono font-medium text-[34px] tracking-[-0.5px] m-0">
      <%= title_html %>
    </h1>
  </div>

  <div
    class="
      grid <%= metric_grid_class %> gap-6 justify-end text-right
      max-lg:justify-start max-lg:text-left max-sm:overflow-x-auto wrapper-padding-overflow overflow-x-scroll
    "
  >
    <% unless competition_over? %>
      <div>
        <div class="<%= meta_num_class %>"><%= days_left %></div>
        <div class="<%= meta_label_class %>">Days<br>Left</div>
      </div>
    <% end %>

    <div>
      <div class="<%= meta_num_class %>"><%= @rider_count %></div>
      <div class="<%= meta_label_class %>">Riders</div>
    </div>

    <div>
      <div class="<%= meta_num_class %>">
        <span class="unit-imperial"><%= number_display(total_miles) %></span>

        <span class="unit-metric hidden"><%= number_display(total_km) %></span>
      </div>

      <div class="<%= meta_label_class %>">
        <span class="unit-imperial">mi ridden</span>
        <span class="unit-metric hidden">km ridden</span>
      </div>
    </div>

    <div>
      <div class="<%= meta_num_class %>">
        <% if total_feet >= 1_000 %>
          <span class="unit-imperial">
            <%= thousands_display(total_feet) %>
          </span>
          <span class="unit-metric hidden">
            <%= thousands_display(total_meters) %>
          </span>
        <% else %>
          <span class="unit-imperial"><%= number_display(total_feet) %></span>
          <span class="unit-metric hidden">
            <%= number_display(total_meters) %>
          </span>
        <% end %>
      </div>

      <div class="<%= meta_label_class %>">
        <span class="unit-imperial">ft climbed</span>
        <span class="unit-metric hidden">m climbed</span>
      </div>
    </div>

    <% if show_everyday_riders? %>
      <div>
        <div class="<%= meta_num_class %>"><%= @everyday_rider_count %></div>
        <div class="<%= meta_label_class %>">Everyday<br>Riders</div>
      </div>
    <% end %>
  </div>
</header>
