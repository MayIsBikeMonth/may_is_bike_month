<section class="mb-8 lg:mb-16 lg:grid lg:grid-cols-[auto_1fr] lg:gap-x-6 lg:items-center">
  <h4
    class="
      font-mono text-[11px] font-medium uppercase tracking-[0.14em]
      text-purple-300 dark:text-purple-400 mb-1.5 lg:m-0 text-left
    "
  >
    Rules
  </h4>

  <ul
    class="
      flex flex-col lg:flex-row lg:flex-wrap list-none gap-y-1.5 gap-x-[22px]
      text-[13px] text-purple-400 dark:text-purple-300 m-0 p-0
    "
  >
    <% if @competition.legacy? %>
      <li>
        Winner rode the most total miles in <%= @competition.period_display %>
      </li>
      <li>Ties broken by total elevation</li>
      <li>
        First place chose what's for dinner, second and last place had to cook
      </li>
      <li>
        Pre-Strava &mdash; totals imported from
        <%= link_to "the original spreadsheet", @competition.legacy_url, class: "twlink", target: "_blank", rel: "noopener" %>
      </li>
    <% else %>
      <li>
        Winner is the person who rides the most days in
        <%= @competition.period_display %>
      </li>
      <li>Ties are broken by total distance</li>
      <li>
        First place chooses what's for dinner, second and last place have to
        cook
      </li>
      <li>Activities that count: <%= activity_types_display %></li>
      <li>
        You have to ride at least
        <span class="unit-imperial"><%= daily_distance_miles %> miles</span>
        <span class="unit-metric hidden"><%= daily_distance_km %> km</span> in a
        day for it to count
      </li>
    <% end %>
  </ul>
</section>
