<%= render(Punchcard::Header::Component.new(
  competition: @competition,
  rider_count: @competition_users.size,
  total_miles:,
  total_feet:,
  everyday_rider_count:
)) %>

<%= render(Punchcard::Rules::Component.new(competition: @competition)) %>

<%= render(Punchcard::Ridge::Component.new(daily_totals:)) %>

<%= render(Punchcard::Axis::Component.new(period_dates:)) %>

<% @competition_users.each_with_index do |competition_user, index| %>
  <%= render(Punchcard::UserRow::Component.new(
    competition_user:,
    competition: @competition,
    rank: index + 1,
    period_date_strings:,
    user_daily: user_daily(competition_user)
  )) %>
<% end %>

<%= render(Punchcard::Footer::Component.new(
  updated_at: @updated_at,
  competition: @competition,
  competitions: @competitions
)) %>
