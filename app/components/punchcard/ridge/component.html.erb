<div
  class="
    pt-1 pb-8 grid grid-cols-[220px_1fr_110px] gap-x-3 items-end pb-1.5
    max-lg:grid-cols-1 max-lg:gap-x-0
  "
>
  <div
    class="
      font-mono text-[11px] text-purple-300 dark:text-purple-400 uppercase
      tracking-[0.12em] text-right pr-1 leading-none pb-2
      max-lg:order-2 max-lg:text-left max-lg:pr-0 max-lg:pt-1.5 max-lg:pb-0
    "
  >
    Daily total
  </div>

  <div class="max-lg:order-1">
    <div class="grid grid-cols-[repeat(31,1fr)] gap-0.5 mb-1 items-end">
      <% bars.each do |bar| %>
        <% if bar[:weekend_label] %>
          <span
            class="
              justify-self-center [writing-mode:vertical-rl] rotate-180
              font-mono text-[10px] uppercase tracking-[0.1em]
              text-purple-300 dark:text-purple-400
            "
          >
            <%= bar[:weekend_label] %>
          </span>
        <% else %>
          <span></span>
        <% end %>
      <% end %>
    </div>

    <div class="grid grid-cols-[repeat(31,1fr)] gap-0.5 items-end">
      <% bars.each do |bar| %>
        <% if bar[:upcoming] %>
          <span
            class="flex flex-col items-stretch rounded-[1px]"
            title="<%= bar[:title] %>"
          >
            <span
              class="block w-full rounded-[1px]"
              style="height:<%= "%.1f" % bar[:height_px] %>px"
              aria-hidden="true"
            ></span>

            <span
              class="
                block text-center text-purple-300 dark:text-purple-400
                font-mono text-[11px] pt-1
              "
            >
              <%= bar[:day] %>
            </span>
          </span>
        <% else %>
          <button
            type="button"
            class="
              flex flex-col items-stretch p-0 border-0 bg-transparent
              cursor-pointer outline-none rounded-[1px] transition-shadow
              hover:ring-1 hover:ring-purple-300 dark:hover:ring-purple-600
              focus-visible:ring-[2px] focus-visible:ring-purple-400
              dark:focus-visible:ring-purple-500 aria-pressed:ring-2
              aria-pressed:ring-purple-700 dark:aria-pressed:ring-purple-100
            "
            title="<%= bar[:title] %>"
            aria-pressed="false"
            data-action="click->punch#toggleDay"
            data-punch-target="ridgeBar"
            data-date="<%= bar[:date_string] %>"
          >
            <span
              class="
                block w-full bg-gradient-to-b from-purple-300 to-purple-500
                dark:from-purple-700 dark:to-purple-500 rounded-[1px] opacity-90
              "
              style="height:<%= "%.1f" % bar[:height_px] %>px"
              aria-hidden="true"
            ></span>

            <span
              class="
                block text-center text-purple-300 dark:text-purple-400
                font-mono text-[11px] pt-1
              "
            >
              <%= bar[:day] %>
            </span>
          </button>
        <% end %>
      <% end %>
    </div>
  </div>

  <div></div>
</div>
