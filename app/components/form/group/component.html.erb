<div class="mb-4">
  <% if check_box? %>
    <%= @form_builder.label @attribute,
      @form_builder.check_box(@attribute, {class: "cursor-pointer"}.merge(@html_options)) +
        tag.span(@label_text),
      class: "inline-flex cursor-pointer items-center gap-2 text-sm font-medium text-gray-700 dark:text-gray-300" %>
  <% else %>
    <%= @form_builder.label @attribute, @label_text, class: Form::Group::Component::LABEL_CLASSES %>
    <%= render(Form::Input::Component.new(form_builder: @form_builder, attribute: @attribute, kind: @kind, html_options: @html_options)) %>
  <% end %>
</div>
