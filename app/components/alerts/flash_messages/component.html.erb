<div
  class="
    fixed bottom-8 md:bottom-12 left-0 right-0 z-50 max-w-screen-xl mx-auto px-4
    pointer-events-none
  "
>
  <div
    class="
      w-full md:w-auto md:max-w-xs md:min-w-140 flex flex-col gap-2
      pointer-events-auto
    "
  >
    <% messages.each do |msg| %>
      <%= render UI::Alert::Component.new(text: msg[:text], kind: msg[:kind], dismissable: true, margin_classes: "mb-0") %>
    <% end %>
  </div>
</div>
