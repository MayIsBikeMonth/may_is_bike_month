# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# For local deploys, secrets come from 1Password and gh CLI.
# For CI deploys, secrets are set as env vars — see .kamal/secrets-ci

KAMAL_REGISTRY_PASSWORD=$(gh auth token)

SECRETS=$(kamal secrets fetch --adapter 1password --account bike-index --from Kamal/MayIsBikeMonth RAILS_MASTER_KEY SECRET_KEY_BASE HONEYBADGER_API_KEY POSTGRES_PASSWORD STRAVA_CLIENT_ID STRAVA_SECRET DEVISE_SECRET_KEY DEVISE_PEPPER S3_ACCESS_KEY_ID S3_SECRET_ACCESS_KEY S3_ENDPOINT HONEYBADGER_CHECKIN_URL)
RAILS_MASTER_KEY=$(kamal secrets extract RAILS_MASTER_KEY ${SECRETS})
SECRET_KEY_BASE=$(kamal secrets extract SECRET_KEY_BASE ${SECRETS})
HONEYBADGER_API_KEY=$(kamal secrets extract HONEYBADGER_API_KEY ${SECRETS})
POSTGRES_PASSWORD=$(kamal secrets extract POSTGRES_PASSWORD ${SECRETS})
STRAVA_CLIENT_ID=$(kamal secrets extract STRAVA_CLIENT_ID ${SECRETS})
STRAVA_SECRET=$(kamal secrets extract STRAVA_SECRET ${SECRETS})
DEVISE_SECRET_KEY=$(kamal secrets extract DEVISE_SECRET_KEY ${SECRETS})
DEVISE_PEPPER=$(kamal secrets extract DEVISE_PEPPER ${SECRETS})
S3_ACCESS_KEY_ID=$(kamal secrets extract S3_ACCESS_KEY_ID ${SECRETS})
S3_SECRET_ACCESS_KEY=$(kamal secrets extract S3_SECRET_ACCESS_KEY ${SECRETS})
S3_ENDPOINT=$(kamal secrets extract S3_ENDPOINT ${SECRETS})
HONEYBADGER_CHECKIN_URL=$(kamal secrets extract HONEYBADGER_CHECKIN_URL ${SECRETS})
