#!/usr/bin/env ruby
# frozen_string_literal: true

#/ Usage: bin/setup_deploy
#/
#/ Configures Kamal deployment for this app. Interactive — prompts for all
#/ required values.
#/
#/ Assumes you are logged in to both `gh` and `op` (1Password CLI).
#/
#/ Updates:
#/   - config/deploy.yml (server IP, deploy host, GHCR registry)
#/   - .kamal/secrets (1Password account)
#/   - config/environments/production.rb (mailer host)
#/   - Creates a 1Password item in the Kamal vault with deploy secrets

require "fileutils"
require "json"
require "securerandom"

def prompt(question, default: nil)
  if default
    print "#{question} [#{default}]: "
  else
    print "#{question}: "
  end
  answer = $stdin.gets.chomp
  answer.empty? ? default : answer
end

root = File.expand_path("..", __dir__)

# --- Gather inputs ---

deploy_host = prompt("Deploy host (e.g. myapp.example.bikeicorn.com)?")
if deploy_host.nil? || deploy_host.empty?
  puts "Deploy host is required."
  exit 1
end

server_ip = prompt("Server IP address?")
if server_ip.nil? || server_ip.empty?
  puts "Server IP is required."
  exit 1
end

# Detect GitHub username from gh CLI
gh_username = `gh api user --jq .login 2>/dev/null`.strip
github_username = prompt("GitHub username (for GHCR registry)?", default: gh_username)

# Detect 1Password account
op_accounts = `op account list --format json 2>/dev/null`
op_account = nil
unless op_accounts.empty?
  accounts = JSON.parse(op_accounts)
  if accounts.length == 1
    op_account = accounts.first["url"].split(".").first
  else
    puts "\nAvailable 1Password accounts:"
    accounts.each_with_index do |a, i|
      puts "  #{i + 1}. #{a["url"]} (#{a["email"]})"
    end
    choice = prompt("Which account?", default: "1")
    op_account = accounts[choice.to_i - 1]["url"].split(".").first
  end
end

puts
puts "Configuration:"
puts "  Deploy host:  #{deploy_host}"
puts "  Server IP:    #{server_ip}"
puts "  GitHub user:  #{github_username}"
puts "  1Password:    #{op_account}"
puts

changed = 0

# --- Update config/deploy.yml ---

deploy_yml = "#{root}/config/deploy.yml"
if File.exist?(deploy_yml)
  content = File.read(deploy_yml)
  original = content.dup

  content.gsub!(/server_ip = ".*?"/, "server_ip = \"#{server_ip}\"")
  content.gsub!(/app_host = ".*?"/, "app_host = \"#{deploy_host}\"")
  content.gsub!(/username: .*$/, "username: #{github_username}")
  content.gsub!(%r{image: .+/<%}, "image: #{github_username}/<%")

  if content != original
    File.write(deploy_yml, content)
    puts "  updated: config/deploy.yml"
    changed += 1
  end
end

# --- Update .kamal/secrets ---

secrets_file = "#{root}/.kamal/secrets"
if File.exist?(secrets_file)
  content = File.read(secrets_file)
  original = content.dup

  content.gsub!(/--account [\w-]+/, "--account #{op_account}")

  if content != original
    File.write(secrets_file, content)
    puts "  updated: .kamal/secrets"
    changed += 1
  end
end

# --- Update production.rb mailer host ---

prod_rb = "#{root}/config/environments/production.rb"
if File.exist?(prod_rb)
  content = File.read(prod_rb)
  original = content.dup

  content.gsub!(/default_url_options = \{host: ".*?"\}/, "default_url_options = {host: \"#{deploy_host}\"}")

  if content != original
    File.write(prod_rb, content)
    puts "  updated: config/environments/production.rb"
    changed += 1
  end
end

# --- Create 1Password item ---

# Detect app name from service in deploy.yml
app_name = File.read(deploy_yml).match(/app_name = "(.+?)"/)[1] rescue "app"
pascal_name = app_name.split("_").map(&:capitalize).join

# Get GitHub repo HTTPS URL
repo_url = `gh repo view --json url --jq .url 2>/dev/null`.strip
repo_url = nil if repo_url.empty?

# Generate a random database password
db_password = SecureRandom.alphanumeric(32)

# Read master key
master_key_file = "#{root}/config/master.key"
master_key = File.exist?(master_key_file) ? File.read(master_key_file).strip : "REPLACE_ME"

# Build op item create command
op_cmd = [
  "op", "item", "create",
  "--account", op_account,
  "--vault", "Kamal",
  "--category", "login",
  "--title", pascal_name,
  "RAILS_MASTER_KEY=#{master_key}",
  "HONEYBADGER_API_KEY=REPLACE_ME",
  "POSTGRESQL_PASSWORD=#{db_password}"
]
op_cmd += ["--url", repo_url] if repo_url

puts
puts "  Creating 1Password item '#{pascal_name}' in Kamal vault..."
result = system(*op_cmd)

if result
  puts "  created: 1Password item '#{pascal_name}'"
  changed += 1
else
  puts "  WARNING: Failed to create 1Password item. Create it manually in the Kamal vault."
end

puts
puts "Done! Updated #{changed} files."
puts
puts "Next steps:"
puts "  1. Add your SSH key to the server: ssh root@#{server_ip}"
puts "  2. Point DNS for #{deploy_host} to #{server_ip} (DNS only, not proxied)"
puts "  3. Update HONEYBADGER_API_KEY in 1Password (Kamal/#{pascal_name})"
puts "  4. Deploy: bin/kamal setup"

# --- Offer to self-destruct ---

remove = prompt("Remove bin/setup_deploy? (y/n)", default: "y")
if remove.downcase.start_with?("y")
  FileUtils.rm(__FILE__)
  puts
  puts "  removed: bin/setup_deploy"
end
